---
import Base from "../layouts/Base.astro";

// The embeddable grants widget, shown as clients see it on their own
// (light) sites. Localhost while testing; point at the production host
// before deploying. No bg/color override — the widget renders its own
// greyish dashboard surface (grey backdrop, white cards, status tabs).
const EMBED_URL = "https://agryq.com/embed/grants/?slug=testclient&redirect_url=https://alidbouk.com/agryq";
// const EMBED_URL = "http://localhost:4321/embed/grants/?slug=testclient&theme=dark&redirect_url=https://alidbouk.com/agryq";
---
<Base
  title="Agryq — Ali Dbouk"
  description="Agryq automates agricultural grant discovery and analysis across Spain. Live demo of the embeddable grants widget."
>
  <section class="section page">
    <div class="shell">
      <p class="back mono-sm" data-reveal><a href="/#work">← Ali Dbouk</a></p>

      <p class="label" data-reveal style="--reveal-delay: 60ms;">2025–Present · Co-Founder</p>
      <h1 data-reveal style="--reveal-delay: 100ms;">Agryq</h1>

      <p class="lede" data-reveal style="--reveal-delay: 150ms;">
        An AI and web-scraping pipeline that automates agricultural grant
        discovery and analysis across Spain. It transforms raw government sources to
        structured, searchable data, and notifies customers of grants which match their criteria. 
        One strategy to increase our presence is to have media companies embed the grants explorer below
        directly into their own sites; this is the live widget, exactly as
        delivered.
      </p>

      <div class="demo-controls mono-sm" data-reveal style="--reveal-delay: 180ms;">
        <span class="view-label">View</span>
        <div class="view-toggle" role="tablist" aria-label="Switch widget layout">
          <button class="view-btn active" id="btn-desktop" role="tab" aria-selected="true">Desktop</button>
          <button class="view-btn" id="btn-mobile" role="tab" aria-selected="false">Mobile</button>
        </div>
      </div>

      <div class="demo-stage" data-reveal style="--reveal-delay: 200ms;">
        <div class="demo" id="demo-frame">
          <iframe
            src={EMBED_URL}
            width="100%"
            height="800"
            frameborder="0"
            allowtransparency="true"
            style="border:none; background:transparent;"
          ></iframe>
          <script src="https://agryq.com/embed.js"></script>
        </div>
      </div>

      <p class="meta mono-sm" data-reveal>
        Embedded via <code>&lt;iframe&gt;</code> ·
        <a href="https://agryq.com" target="_blank" rel="noopener noreferrer">agryq.com ↗</a>
      </p>
    </div>
  </section>
</Base>

<style>
  .page { padding-top: clamp(56px, 11vh, 110px); padding-bottom: clamp(48px, 9vh, 88px); }

  .back { margin-bottom: clamp(32px, 6vh, 56px); }
  .back a { color: var(--muted); text-decoration: none; }
  .back a:hover { color: var(--accent-strong); }

  h1 {
    font-size: clamp(2rem, 5.5vw, 2.9rem);
    font-weight: 480;
    margin: 10px 0 18px;
  }
  .lede { max-width: 58ch; color: var(--body); margin-bottom: 34px; }

  /* Desktop view breaks out of the 700px text column to near-full viewport
     width. Centering uses a transform here (not on the data-reveal wrapper,
     which animates its own transform). */
  .demo {
    width: min(100vw - var(--gutter) * 2, 1500px);
    position: relative;
    left: 50%;
    transform: translateX(-50%);
    border: 1px solid var(--line);
    overflow: hidden;
    transition: width 0.5s var(--ease), height 0.5s var(--ease);
  }
  .demo-bar {
    display: flex;
    justify-content: space-between;
    gap: 14px;
    padding: 9px 14px;
    border-bottom: 1px solid var(--line);
    color: var(--faint);
  }
  .demo-slug { color: var(--muted); }
  .demo iframe {
    display: block;
    width: 100%;
    /* single height property (no min-height) so the shrink/grow transition
       has no governing-property crossover that would kink the motion */
    height: min(82vh, 700px);
    border: 0;
    /* the widget ships light; declaring the iframe's color-scheme to match
       prevents the browser painting an opaque (white) backdrop on this
       dark page, so the embed's transparent background shows through */
    /* color-scheme: light; */
    background: transparent;
    transition: height 0.5s var(--ease);
  }

  .meta { color: var(--faint); margin-top: 16px; }
  .meta code { font-size: 0.95em; }
  .meta a { color: var(--muted); }
  .meta a:hover { color: var(--accent-strong); }

  .demo-controls {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 12px;
  }
  .view-label {
    color: var(--faint);
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }
  .view-toggle {
    display: inline-flex;
    gap: 3px;
    padding: 3px;
    border: 1px solid var(--line);
    border-radius: 999px;
    background: var(--bg-soft);
  }
  .view-btn {
    padding: 5px 16px;
    border: none;
    border-radius: 999px;
    background: transparent;
    color: var(--muted);
    cursor: pointer;
    font-family: inherit;
    font-size: inherit;
    letter-spacing: inherit;
    transition: color 0.15s, background 0.15s;
  }
  .view-btn:hover { color: var(--body); }
  .view-btn.active {
    background: var(--text);
    color: var(--bg);
  }

  /* mobile view: matches the page text column width (≈620px) — still below
     the widget's 768px breakpoint, so the embed stays in its mobile layout.
     Centered via the inherited transform, so only width animates. */
  .demo.mobile {
    width: 100%;
  }
  .demo.mobile iframe {
    height: min(82vh, 780px);
  }
</style>

<script>
  const btnDesktop = document.getElementById('btn-desktop');
  const btnMobile  = document.getElementById('btn-mobile');
  const demo       = document.getElementById('demo-frame');

  btnDesktop?.addEventListener('click', () => {
    demo?.classList.remove('mobile');
    btnDesktop.classList.add('active');
    btnDesktop.setAttribute('aria-selected', 'true');
    btnMobile?.classList.remove('active');
    btnMobile?.setAttribute('aria-selected', 'false');
  });

  btnMobile?.addEventListener('click', () => {
    demo?.classList.add('mobile');
    btnMobile.classList.add('active');
    btnMobile.setAttribute('aria-selected', 'true');
    btnDesktop?.classList.remove('active');
    btnDesktop?.setAttribute('aria-selected', 'false');
  });
</script>
