---
const { name } = Astro.props;
const year = new Date().getFullYear();
---
<footer class="foot">
  <div class="shell">
    <hr class="rule" />
    <div class="row mono-sm">
      <span>© {year} {name}</span>
    </div>
  </div>
</footer>

<style>
  .foot { padding: clamp(40px, 7vh, 64px) 0 36px; }
  .row {
    display: flex;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
    color: var(--faint);
    padding-top: 18px;
  }
</style>
